{
    "name": "kamers",
    "private": true,
    "version": "1.0.0",
    "workspaces": [
        "packages/shared",
        "packages/server",
        "packages/client"
    ],
    "scripts": {
        "bootstrap": "bash ./scripts/bootstrap",
        "dev": "node scripts/dev.mjs",
        "dev:server": "npm run dev -w packages/server -- -- -E development",
        "dev:client": "npm run dev -w packages/client -- -- -E development",
        "build:shared": "npm run build -w packages/shared",
        "build:server": "npm run build -w packages/server",
        "build:client": "npm run build -w packages/client",
        "build:dev": "npm run build:shared && npm run build:server && npm run build:client -- -- -- -- -E development",
        "db:migrate": "npm run db:migrate -w packages/server",
        "db:deploy": "npm run db:deploy -w packages/server",
        "db:generate": "npm run db:generate -w packages/server",
        "db:seed": "npm run db:seed -w packages/server",
        "db:studio": "npm run db:studio -w packages/server",
        "db:studio:dev": "npm run db:studio -- -- --config prisma.config.dev.ts",
        "test": "npm run test -w packages/shared && npm run test -w packages/server && npm run test -w packages/client",
        "test:server": "npm run test -w packages/server",
        "test:client": "npm run test -w packages/client",
        "test:shared": "npm run test -w packages/shared",
        "clean:server": "rm -rf packages/server/node_modules packages/server/dist packages/server/data",
        "clean:client": "rm -rf packages/client/node_modules packages/client/dist",
        "clean:shared": "rm -rf packages/shared/node_modules packages/shared/dist",
        "clean": "npm run clean:shared && npm run clean:client && npm run clean:server"
    },
    "devDependencies": {
        "@types/node": "25.3.0",
        "typescript": "5.9.3",
        "vitest": "^4.0.18"
    }
}
