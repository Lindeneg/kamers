{
    "name": "kamers",
    "private": true,
    "version": "1.0.0",
    "workspaces": [
        "packages/shared",
        "packages/server",
        "packages/client"
    ],
    "scripts": {
        "bootstrap": "bash ./scripts/bootstrap",
        "dev": "node scripts/dev.mjs",
        "dev:server": "npm run dev -w packages/server -- -- -E development",
        "dev:client": "npm run dev -w packages/client -- -- -E development",
        "build:shared": "npm run build -w packages/shared",
        "build:server": "npm run build -w packages/server",
        "build:client": "npm run build -w packages/client",
        "build": "npm run build:shared && npm run build:server && npm run build:client",
        "db:migrate": "npm run db:migrate -w packages/server",
        "db:generate": "npm run db:generate -w packages/server",
        "db:seed": "npm run db:seed -w packages/server",
        "db:studio": "npm run db:studio -w packages/server"
    },
    "devDependencies": {
        "@types/node": "25.3.0",
        "typescript": "5.9.3"
    }
}
