{
    "name": "@kamers/server",
    "version": "1.0.0",
    "type": "module",
    "scripts": {
        "dev": "tsx watch src/index.ts",
        "build": "tsc --noEmit && esbuild src/index.ts --bundle --platform=node --format=esm --outfile=dist/index.js --packages=external --banner:js=\"import{createRequire}from'module';const require=createRequire(import.meta.url);\"",
        "start": "node dist/index.js",
        "db:migrate": "prisma migrate dev",
        "db:generate": "prisma generate",
        "db:seed": "tsx prisma/seed.ts",
        "db:studio": "prisma studio",
        "test": "vitest run"
    },
    "dependencies": {
        "@kamers/shared": "*",
        "@prisma/adapter-better-sqlite3": "7.4.1",
        "@prisma/client": "7.4.1",
        "bcrypt": "6.0.0",
        "cookie-parser": "1.4.7",
        "cors": "2.8.6",
        "dotenv": "17.3.1",
        "express": "5.2.1",
        "jsonwebtoken": "9.0.3",
        "pino": "10.3.1",
        "pino-http": "11.0.0",
        "pino-pretty": "13.1.3",
        "zod": "4.3.6"
    },
    "devDependencies": {
        "@types/bcrypt": "6.0.0",
        "@types/cookie-parser": "1.4.10",
        "@types/cors": "2.8.19",
        "@types/express": "5.0.6",
        "@types/jsonwebtoken": "9.0.10",
        "@types/supertest": "^7.2.0",
        "esbuild": "^0.27.3",
        "prisma": "7.4.1",
        "supertest": "^7.2.2",
        "tsx": "4.21.0",
        "vitest": "^4.0.18"
    }
}
